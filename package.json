{
  "name": "skill-sync",
  "version": "0.3.0",
  "description": "Централизованный менеджер установки и обновления skills для LLM-агентов",
  "author": "eugen1408",
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "svelte-check --tsconfig tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.9",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^4.15.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^22.10.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eugen1408/skill-sync.git"
  }
}
